{
  "version": 1,
  "name": "Genshin-like Soft Game Anime v2 Bright Viewer",
  "description": "A brighter hand-tuned baseline for HaoRender-GI's current IF model. It leans toward game-character preview readability: lifted fill, softer blue-violet shadow, lower normal intensity, restrained cream highlight, subtle outline, and gentle rim. Current limitation: HaoRender-GI does not yet expose material albedo lift or ramp textures, so very dark clothing textures cannot be made truly Genshin-like by lighting parameters alone.",
  "sourcePrompt": "人工设计 v2：仿原神/二游柔和角色渲染，优先让当前 IF 模型更亮、更柔和、更少塑料感。",
  "focus": "Toon",
  "preferredPipeline": "Raster",
  "lookDev": {
    "shadingModel": "Phong",
    "exposure": 1.22,
    "normalStrength": 0.72,
    "enableShadows": true,
    "enableBackfaceCulling": true,
    "pbr": {
      "iblEnabled": true,
      "iblDiffuseStrength": 0.95,
      "iblSpecularStrength": 0.58,
      "skyLightStrength": 0.48,
      "metallicChannel": 2,
      "roughnessChannel": 1,
      "aoChannel": 0,
      "emissiveChannel": 0
    },
    "phong": {
      "hardSpecular": false,
      "useTonemap": true,
      "primaryLightOnly": false,
      "secondaryLightScale": 0.46,
      "diffuseStrength": 1.12,
      "ambientStrength": 0.135,
      "ambientColor": { "r": 1.0, "g": 0.985, "b": 0.96 },
      "specularStrength": 0.24,
      "specularTint": { "r": 1.0, "g": 0.955, "b": 0.88 },
      "smoothness": 0.66,
      "specularMapWeight": 0.42,
      "shininess": 42.0,
      "rimStrength": 0.26,
      "rimPower": 2.05,
      "rimTint": { "r": 0.84, "g": 0.92, "b": 1.0 },
      "toon": {
        "enabled": true,
        "diffuseSteps": 3.0,
        "diffuseSoftness": 0.135,
        "shadowFloor": 0.14,
        "litFloor": 0.52,
        "rampBias": 0.03,
        "rampContrast": 0.82,
        "shadowMapStrength": 0.32,
        "shadowThreshold": 0.385,
        "shadowSoftness": 0.175,
        "shadowTint": { "r": 0.73, "g": 0.77, "b": 0.98 },
        "highlightThreshold": 0.42,
        "highlightSoftness": 0.105,
        "highlightStrength": 0.44,
        "highlightTint": { "r": 1.0, "g": 0.955, "b": 0.90 },
        "rimThreshold": 0.34,
        "rimSoftness": 0.13,
        "materialOverrideEnabled": true,
        "materialTextureStrength": 0.82,
        "materialLift": 0.08,
        "materialSaturation": 1.02,
        "materialContrast": 0.82
      },
      "outline": {
        "enabled": true,
        "widthPixels": 1.05,
        "opacity": 0.42,
        "depthBias": 0.0012,
        "color": { "r": 0.07, "g": 0.075, "b": 0.11 }
      }
    },
    "rayTrace": {
      "sceneMode": "LoadedModel",
      "viewMode": "Lit",
      "integrator": "PathTraceNee",
      "ambientStrength": 0.05,
      "shadowStrength": 1.0,
      "maxBounces": 20,
      "maxNeeBounces": 2,
      "samplesPerFrame": 8,
      "enableNee": true,
      "enablePhotonCache": true,
      "photonRadius": 0.22,
      "photonIntensity": 1.0
    }
  }
}
